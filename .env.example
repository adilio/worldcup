# football-data.org free tier (World Cup competition code: WC, 10 req/min)
FOOTBALL_DATA_API_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# Optional secondary live provider. Do not enable unless football-data.org
# proves insufficient. Free quota is only 100 requests/day.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
ENABLE_API_FOOTBALL=false
